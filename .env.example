# ============================================
# Admin (NextAuth v5)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of email addresses allowed to access /admin
ADMIN_EMAILS=nishi240masa@gmail.com

# ============================================
# Repository
# ============================================
# 'json' — local JSON file persistence under /data
#   dev/test の default。node:fs に依存しており Cloudflare Pages (edge runtime) では使用不可。
# 'github' — GitHub Contents API driver
#   production (NODE_ENV=production) の default。Cloudflare Pages へのデプロイで必須。
#   後述の GITHUB_TOKEN / OWNER / REPO が無いと起動時に throw する。
# 明示指定すれば常に上書き可能 (CI 用に REPOSITORY_DRIVER=json を渡す等)。
REPOSITORY_DRIVER=json

# ============================================
# GitHub Contents API driver settings
# ============================================
# REPOSITORY_DRIVER=github のときに必須。
# Cloudflare Pages dashboard では Secret として登録すること (GITHUB_TOKEN は repo:contents 権限)。
# production deploy では以下が全て揃っていないと起動時に throw する:
#   - GITHUB_TOKEN  (Personal Access Token / fine-grained で contents:write が付与されたもの)
#   - GITHUB_OWNER  (例: nishi240masa)
#   - GITHUB_REPO   (例: my-portfolio)
#   - GITHUB_BRANCH (省略時 develop)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=develop

# ============================================
# Public API (legacy - retained for future remote backend)
# ============================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_USE_MOCK_DATA=true
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_API_RETRY_COUNT=3

# ============================================
# Site & Analytics
# ============================================
# 公開URLのベース（metadataBase / robots / sitemap で使用）
NEXT_PUBLIC_SITE_URL=
# Cloudflare Web Analytics トークン（未設定時はスクリプトを出力しない）
NEXT_PUBLIC_CF_BEACON_TOKEN=
