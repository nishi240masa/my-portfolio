# ============================================
# Admin (NextAuth v5)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of email addresses allowed to access /admin
ADMIN_EMAILS=nishi240masa@gmail.com

# ============================================
# Repository
# ============================================
# 'json' (default) — local JSON file persistence under /data
# Future: 'db' — Prisma / Drizzle-backed repository
REPOSITORY_DRIVER=json

# ============================================
# Public API (legacy - retained for future remote backend)
# ============================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_USE_MOCK_DATA=true
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_API_RETRY_COUNT=3

# ============================================
# Site & Analytics
# ============================================
# 公開URLのベース（metadataBase / robots / sitemap で使用）
NEXT_PUBLIC_SITE_URL=
# Cloudflare Web Analytics トークン（未設定時はスクリプトを出力しない）
NEXT_PUBLIC_CF_BEACON_TOKEN=
