# ============================================
# Admin (NextAuth v5)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of email addresses allowed to access /admin
ADMIN_EMAILS=nishi240masa@gmail.com

# ============================================
# Repository driver
# ============================================
# 利用可能な値:
#   'json'   — ローカル JSON ファイル永続化 (data/*.json)。
#              dev / test の **default**。`node:fs` を使うため Node.js runtime 専用。
#   'github' — GitHub Contents API 経由でリポジトリにコミット。
#              Cloudflare Pages (Edge Runtime) **本番では必須**。
#
# 本番 (Cloudflare Pages) では `REPOSITORY_DRIVER=github` を必ず設定すること。
# 設定しないと Edge Runtime 上で json driver が動かず 500 になる。
REPOSITORY_DRIVER=json

# ============================================
# GitHub commit driver settings
# ============================================
# REPOSITORY_DRIVER=github のときに必須。
# 本番 (CF Pages) では Cloudflare dashboard の Environment variables に
# **secret** として登録する (リポジトリにコミットしない)。
#
# GITHUB_TOKEN:  fine-grained PAT 推奨。対象リポジトリの
#                "Contents: Read and write" 権限が必要。
# GITHUB_OWNER:  リポジトリの owner (例: nishi240masa)
# GITHUB_REPO:   リポジトリ名 (例: my-portfolio)
# GITHUB_BRANCH: コミット先ブランチ (例: develop / main)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=develop

# ============================================
# Public API (legacy - retained for future remote backend)
# ============================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_USE_MOCK_DATA=true
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_API_RETRY_COUNT=3

# ============================================
# Site & Analytics
# ============================================
# 公開URLのベース（metadataBase / robots / sitemap で使用）
NEXT_PUBLIC_SITE_URL=
# Cloudflare Web Analytics トークン（未設定時はスクリプトを出力しない）
NEXT_PUBLIC_CF_BEACON_TOKEN=
